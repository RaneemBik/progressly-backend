# ── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── MongoDB ─────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://localhost:27017/progressly
# Atlas (Production):
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/progressly?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string-minimum-32-characters
JWT_EXPIRATION=7d

# ── Frontend URL (used in invite email links and CORS) ──────────
# Local:
FRONTEND_URL=http://localhost:5173
# Production example:
# FRONTEND_URL=https://your-app.vercel.app

# ── Backend API URL (used by frontend) ────────────────────────
# Local:
BACKEND_API_URL=http://localhost:3001
# Production example:
# BACKEND_API_URL=https://progressly-backend.onrender.com

# ── SMTP (optional — invites still work without it, link is logged) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# ── CORS Settings ────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
